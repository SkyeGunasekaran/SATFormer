{
  "model": {
    "source": "local_class",
    "module": "models/hyperconnections/modeling_hyperconnections",
    "class_name": "HyperConnectionsForCausalLM",
    "config_module": "models/hyperconnections/configuration_hyperconnections",
    "config_class_name": "HyperConnectionsConfig",
    "from_pretrained": false,
    "pretrained_path": null,
    "config_overrides": {
      "vocab_size": 32000,
      "hidden_size": 1024,
      "num_hidden_layers": 18,
      "num_heads": 16,
      "num_kv_heads": null,
      "qkv_bias": false,
      "qk_norm": true,
      "window_size": null,
      "rope_theta": 10000.0,
      "max_position_embeddings": 4096,
      "hidden_ratio": 4,
      "intermediate_size": 4096,
      "hidden_act": "swish",
      "initializer_range": 0.02,
      "elementwise_affine": true,
      "norm_eps": 1e-6,
      "use_cache": false,
      "tie_word_embeddings": true,
      "fuse_norm": true,
      "fuse_swiglu": true,
      "fuse_cross_entropy": true,
      "fuse_linear_cross_entropy": false,
      "expansion_rate": 4,
      "use_dynamic_hc": true,
      "use_tanh": true,
      "hc_norm_type": "rms"
    }
  },
  "tokenizer": {
    "name_or_path": "NousResearch/Llama-2-7b-hf",
    "save_with_model": true
  },
  "data": {
    "data_dir": "/dev/shm/data",
    "train_prefix": "train",
    "val_prefix": "val",
    "seq_length": 4096
  },
  "training": {
    "batch_size": 32,
    "gradient_accumulation_steps": 2,
    "gradient_checkpointing": false,
    "learning_rate": 1.5e-3,
    "min_lr": 1.5e-4,
    "warmup_tokens": 0.1,
    "max_tokens": 10.0,
    "lr_decay_style": "cosine",
    "weight_decay": 0.1,
    "beta1": 0.9,
    "beta2": 0.95,
    "grad_clip": 1.0,
    "dtype": "bfloat16",
    "compile_model": false,
    "fused_adamw": true
  },
  "checkpointing": {
    "checkpoint_dir": "/dev/shm/checkpoints/hyperresformer/medium",
    "checkpoint_interval": 2000,
    "save_final_model": true
  },
  "logging": {
    "log_interval": 10,
    "eval_interval": 500,
    "eval_iters": 100,
    "wandb_project": "residual-ablation",
    "wandb_run_name": "hyperresformer-medium"
  },
  "system": {
    "seed": 42,
    "num_workers": 16,
    "prefetch_factor": 4,
    "pin_memory": true,
    "persistent_workers": true
  }
}